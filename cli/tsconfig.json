{
    "compilerOptions": {
        
        // We run the CLI through ts-node in production, so we must use a modern target.
        // In particular, downleveling built-in subclasses (ex: `class extends Map`) to ES5 breaks at runtime.
        "target": "ES2021",
        "module": "CommonJS",

        "esModuleInterop": true,
        "skipLibCheck": true,
        "allowJs": true,
        "strict": false,
        "noImplicitAny": true,
        "noImplicitThis": true,
        "strictBindCallApply": true,
        "useUnknownInCatchVariables": true,
        "downlevelIteration": true,

        // Keep symlinked package paths stable for local framework development.
        "preserveSymlinks": true,
        // React
        "jsx": "react-jsx",
        "jsxImportSource": "preact",

        "strictPropertyInitialization": true,
        "strictNullChecks": true,
        
        "baseUrl": "./",
        "outDir": "./bin",

        "paths": {
            "@client/*": [ "../client/*" ],
            "@cli/*": [ "./*" ],
            "@cli/app": [ "./app" ],
            "@cli": [ "./" ],
            "@common/*": [ "../common/*" ],
            "@server/*": [ "../server/*" ]
        },
    },

    "ts-node": {
        "transpileOnly": true,
    },

    "include": ["./"]
}
